{
  "realm": "formularservice",
  "enabled": true,
  "clients": [
    {
      "clientId": "formularservice-web",
      "publicClient": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "https://formularservice-web-production.up.railway.app/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "https://formularservice-web-production.up.railway.app"
      ],
      "protocolMappers": [
        {
          "name": "formularservice-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "formularservice-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "formularservice-api",
      "bearerOnly": true
    }
  ],
  "roles": {
    "realm": [
      { "name": "service-admin" },
      { "name": "project-admin" },
      { "name": "form-editor" },
      { "name": "viewer" }
    ]
  }
}
