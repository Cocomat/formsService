{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "build": {
      "commands": [
        "...",
        "pnpm --filter @formularservice/api prisma:generate",
        "pnpm --filter @formularservice/api build"
      ]
    }
  },
  "deploy": {
    "startCommand": "pnpm --filter @formularservice/api prisma:deploy && pnpm --filter @formularservice/api start"
  }
}
